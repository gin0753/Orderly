{
  "name": "orderly",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:api": "pnpm --filter @orderly/api dev",
    "dev:web": "pnpm --filter @orderly/web dev",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @orderly/api prisma migrate dev",
    "db:seed": "pnpm --filter @orderly/api prisma db seed",
    "db:reset": "pnpm --filter @orderly/api prisma migrate reset",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  },
  "packageManager": "pnpm@10.14.0"
}
